{
  "name": "devproduct-bulk-creator",
  "version": "1.0.45",
  "description": "Bulk create and manage Roblox Developer Products",
  "main": "electron/main.js",
  "author": "Dizzy (Dvyz)",
  "scripts": {
    "start": "webpack --mode development && electron .",
    "build": "webpack --mode production",
    "dev": "webpack --mode development --watch",
    "electron": "electron .",
    "dist": "webpack --mode production && electron-builder --win",
    "publish": "webpack --mode production && electron-builder --win --publish always"
  },
  "build": {
    "appId": "com.devproduct.bulkcreator",
    "productName": "DevProduct Bulk Creator",
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "electron/**/*",
      "src/index.html",
      "src/bundle.js",
      "node_modules/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "owner": "AverageFarmer",
      "repo": "DevProduct-Plugin"
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "electron-updater": "^6.8.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.23.3",
    "babel-loader": "^9.1.3",
    "css-loader": "^6.10.0",
    "electron": "^29.1.0",
    "electron-builder": "^26.8.1",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "style-loader": "^3.3.4",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4"
  }
}
